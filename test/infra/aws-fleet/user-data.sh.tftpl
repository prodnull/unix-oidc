#!/bin/bash
# prmana-ci fleet instance user-data
# Template variables: max_instance_minutes, github_run_id, distro, arch
#
# Purpose: Set a hard shutdown watchdog and write instance metadata.
# This script is pure infrastructure — it does NOT install packages,
# run cargo, or reference prmana binaries. Package installation is
# the responsibility of DT-A.

set -euo pipefail

# ---------------------------------------------------------------------------
# Hard shutdown watchdog (T-DT0-01-05: runaway fleet mitigation layer 2)
#
# `shutdown -h +N` schedules an immediate power-off N minutes from now.
# Combined with instance_initiated_shutdown_behavior = "terminate" in main.tf,
# the instance is fully destroyed when this fires — no stopped-instance charges.
#
# Defense in depth:
#   Layer 1: var.instance_count <= 10 (Terraform variable validation)
#   Layer 2: This watchdog (instance-level, independent of workflow)
#   Layer 3: AWS Budget alarm at 80% of $5 cap (budget.tf)
# ---------------------------------------------------------------------------
shutdown -h +${max_instance_minutes}

# ---------------------------------------------------------------------------
# Instance metadata — written to a known path for log collection.
# Log collector (DT-0-03) greps this file to correlate logs with runs.
# ---------------------------------------------------------------------------
LAUNCHED_AT=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

mkdir -p /etc/prmana-ci

cat > /etc/prmana-ci-metadata <<EOF
github_run_id=${github_run_id}
distro=${distro}
arch=${arch}
launched_at=$${LAUNCHED_AT}
max_instance_minutes=${max_instance_minutes}
EOF

# Also write to the standard metadata path expected by the log collector.
cp /etc/prmana-ci-metadata /etc/prmana-ci/metadata

# ---------------------------------------------------------------------------
# Completion marker — log collector greps this to confirm user-data ran.
# Must be the last line so grep confirms full script execution.
# ---------------------------------------------------------------------------
echo "prmana-ci: user-data complete" | tee -a /var/log/cloud-init-output.log
