#cloud-config
# prmana-ci cloud-init template
# Rendered by Terraform templatefile() at provision time.
# Variables: max_instance_minutes, github_run_id, distro, arch
#
# Purpose: secondary shutdown watchdog + CI metadata file.
# Primary enforcement: Azure Spot eviction_policy=Delete destroys VMs on reclaim.
# This watchdog covers the case where the GitHub Actions workflow exits cleanly
# but the terraform destroy step is delayed or skipped.

runcmd:
  - [ bash, -c, "echo 'prmana-ci: cloud-init starting' > /var/log/prmana-ci.log" ]
  # Write CI metadata for test scripts to consume
  - [ bash, -c, "cat > /etc/prmana-ci-metadata <<METADATA\ngithub_run_id=${github_run_id}\ndistro=${distro}\narch=${arch}\nlaunched_at=$(date -Iseconds)\nmax_instance_minutes=${max_instance_minutes}\nMETADATA" ]
  # Shutdown watchdog: halt the VM after max_instance_minutes to enforce cost cap.
  # `shutdown -h +N` schedules a halt N minutes from now.
  # This runs last so test tooling has the full window.
  - [ bash, -c, "shutdown -h +${max_instance_minutes}" ]
  - [ bash, -c, "echo 'prmana-ci: watchdog armed (${max_instance_minutes} min)' >> /var/log/prmana-ci.log" ]
  - [ bash, -c, "echo 'prmana-ci: cloud-init complete' >> /var/log/prmana-ci.log" ]
