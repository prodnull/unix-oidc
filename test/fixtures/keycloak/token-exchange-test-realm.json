{
  "realm": "token-exchange-test",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "clients": [
    {
      "clientId": "prmana-agent",
      "name": "Unix OIDC Agent (User Machine)",
      "description": "Public client representing the user's machine with DPoP support",
      "enabled": true,
      "publicClient": true,
      "redirectUris": [
        "http://localhost:*",
        "urn:ietf:wg:oauth:2.0:oob"
      ],
      "webOrigins": [
        "*"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "attributes": {
        "oauth2.device.authorization.grant.enabled": "true",
        "oauth2.device.code.lifespan": "300",
        "oauth2.device.polling.interval": "5",
        "oidc.ciba.grant.enabled": "false",
        "dpop.bound.access.tokens": "true"
      },
      "protocolMappers": [
        {
          "name": "preferred_username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "username",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "preferred_username",
            "jsonType.label": "String"
          }
        },
        {
          "name": "acr-loa-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-acr-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        },
        {
          "name": "audience-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "prmana-agent",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        },
        {
          "name": "audience-mapper-jump-host",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "jump-host-a",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "jump-host-a",
      "name": "Jump Host A",
      "description": "Confidential client representing a jump host with token exchange capabilities",
      "enabled": true,
      "publicClient": false,
      "secret": "jump-host-secret",
      "redirectUris": [
        "http://localhost:*"
      ],
      "webOrigins": [
        "*"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "attributes": {
        "oauth2.device.authorization.grant.enabled": "false",
        "oidc.ciba.grant.enabled": "false",
        "dpop.bound.access.tokens": "true",
        "token-exchange-standard-flow.enabled": "true"
      },
      "defaultClientScopes": [
        "target-host-b-audience"
      ],
      "protocolMappers": [
        {
          "name": "preferred_username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "username",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "preferred_username",
            "jsonType.label": "String"
          }
        },
        {
          "name": "acr-loa-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-acr-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        },
        {
          "name": "act-claim-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "act",
            "claim.value": "{\"sub\":\"jump-host-a\",\"client_id\":\"jump-host-a\"}",
            "jsonType.label": "JSON",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "target-host-b",
      "name": "Target Host B",
      "description": "Confidential client representing the target host (audience target for token exchange)",
      "enabled": true,
      "publicClient": false,
      "secret": "target-host-secret",
      "redirectUris": [
        "http://localhost:*"
      ],
      "webOrigins": [
        "*"
      ],
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "attributes": {
        "oauth2.device.authorization.grant.enabled": "false",
        "oidc.ciba.grant.enabled": "false",
        "dpop.bound.access.tokens": "true"
      },
      "protocolMappers": [
        {
          "name": "preferred_username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "username",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "preferred_username",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "testuser",
      "enabled": true,
      "email": "testuser@test.local",
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "testpass",
          "temporary": false
        }
      ],
      "realmRoles": [
        "default-roles-token-exchange-test"
      ]
    },
    {
      "username": "adminuser",
      "enabled": true,
      "email": "adminuser@test.local",
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "adminpass",
          "temporary": false
        }
      ],
      "realmRoles": [
        "default-roles-token-exchange-test"
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "default-roles-token-exchange-test",
        "description": "Default realm roles for token-exchange-test",
        "composite": false
      },
      {
        "name": "token-exchange",
        "description": "Role that allows token exchange operations",
        "composite": false
      }
    ],
    "client": {
      "jump-host-a": [
        {
          "name": "token-exchange-allowed",
          "description": "Allows this client to perform token exchange",
          "composite": false
        }
      ],
      "target-host-b": [
        {
          "name": "audience-target",
          "description": "Allows tokens to be exchanged with this client as audience",
          "composite": false
        }
      ]
    }
  },
  "scopeMappings": [
    {
      "client": "jump-host-a",
      "roles": [
        "token-exchange"
      ]
    }
  ],
  "clientScopeMappings": {
    "target-host-b": [
      {
        "client": "jump-host-a",
        "roles": [
          "audience-target"
        ]
      }
    ]
  },
  "clientScopes": [
    {
      "name": "token-exchange-scope",
      "description": "Scope for token exchange operations",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "target-host-b-audience",
      "description": "Scope that adds target-host-b to the audience",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "audience-target-host-b",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "target-host-b",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "defaultDefaultClientScopes": [],
  "defaultOptionalClientScopes": [
    "offline_access",
    "token-exchange-scope"
  ],
  "components": {
    "org.keycloak.services.clientpolicy.executor.ClientPolicyExecutorProvider": [],
    "org.keycloak.services.clientpolicy.condition.ClientPolicyConditionProvider": []
  },
  "authenticationFlows": [
    {
      "alias": "token-exchange-test-browser",
      "description": "Browser flow for token exchange testing",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-username-password-form",
          "requirement": "REQUIRED",
          "priority": 10
        }
      ]
    }
  ],
  "identityProviderMappers": [],
  "clientPolicies": {
    "policies": []
  },
  "clientProfiles": {
    "profiles": []
  }
}
