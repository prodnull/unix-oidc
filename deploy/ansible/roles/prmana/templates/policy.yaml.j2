# Prmana Policy Configuration
# Generated by Ansible — do not edit manually.
# Managed by: deploy/ansible/roles/prmana/

issuers:
  - issuer_url: "{{ prmana_issuer_url }}"
    client_id: "{{ prmana_client_id }}"
{% if prmana_client_secret %}
    client_secret: "{{ prmana_client_secret }}"
{% endif %}
    dpop_enforcement: {{ prmana_dpop_enforcement }}
{% if prmana_failover_enabled and prmana_failover_secondary_url %}
  - issuer_url: "{{ prmana_failover_secondary_url }}"
    client_id: "{{ prmana_client_id }}"
{% if prmana_client_secret %}
    client_secret: "{{ prmana_client_secret }}"
{% endif %}
    dpop_enforcement: {{ prmana_dpop_enforcement }}
{% endif %}

break_glass:
  enabled: {{ prmana_break_glass_enabled | lower }}
{% if prmana_break_glass_enabled %}
  users:
    - username: "{{ prmana_break_glass_username }}"
      password_hash: "{{ prmana_break_glass_password_hash }}"
  alert_on_use: {{ prmana_break_glass_alert_on_use | lower }}
{% endif %}

security_modes:
  jti_enforcement: {{ prmana_jti_enforcement }}
  dpop_required: {{ prmana_dpop_enforcement }}

audit:
  log_file: "{{ prmana_audit_log }}"
  syslog: {{ prmana_audit_syslog | lower }}
