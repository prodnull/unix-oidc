# Prmana PAM configuration for sshd
# Generated by Ansible — do not edit manually.
# Mode: {{ prmana_pam_mode }}

{% if prmana_pam_mode == "parallel" %}
# Parallel mode: OIDC is sufficient (success = allow, failure = try next)
auth    sufficient    pam_prmana.so
{% elif prmana_pam_mode == "primary" %}
# Primary mode: OIDC first, fall through to password on failure
auth    sufficient    pam_prmana.so
auth    required      pam_unix.so
{% elif prmana_pam_mode == "exclusive" %}
# Exclusive mode: OIDC only (WARNING: break-glass requires separate Match block in sshd_config)
auth    required      pam_prmana.so
{% endif %}
