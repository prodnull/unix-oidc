# prmana configuration
# Managed by Ansible - Do not edit manually

# OIDC Issuer URL (Required)
OIDC_ISSUER={{ prmana_issuer }}

# OIDC Client ID
OIDC_CLIENT_ID={{ prmana_client_id }}

# Token lifetime in seconds
TOKEN_LIFETIME={{ prmana_token_lifetime }}

# Enable DPoP (Demonstrating Proof of Possession)
ENABLE_DPOP={{ prmana_enable_dpop | lower }}

{% if prmana_required_acr | length > 0 %}
# Required Authentication Context Class Reference
REQUIRED_ACR={{ prmana_required_acr }}
{% endif %}

{% if prmana_allowed_groups | length > 0 %}
# Allowed groups (comma-separated)
ALLOWED_GROUPS={{ prmana_allowed_groups | join(',') }}
{% endif %}

# Log level (debug, info, warn, error)
LOG_LEVEL={{ prmana_log_level }}

# SSL certificate verification
VERIFY_SSL={{ prmana_verify_ssl | lower }}

{% if prmana_custom_claims %}
# Custom claims mapping
{% for key, value in prmana_custom_claims.items() %}
CLAIM_{{ key | upper }}={{ value }}
{% endfor %}
{% endif %}
